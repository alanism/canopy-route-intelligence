# Google Cloud / BigQuery. Optional for local demo mode.
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.example.json

# Token contract addresses used by the EVM BigQuery adapter.
USDC_POLYGON_CONTRACT=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDC_ETH_CONTRACT=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Native token price fallbacks.
ETH_PRICE_FALLBACK=3500
POLYGON_PRICE_FALLBACK=0.10

# Optional browser map background. Use a browser-safe public token only.
VITE_MAPBOX_TOKEN=pk.your-public-mapbox-token

# x402 demo settings. The hackathon repo does not execute payments.
X402_PAYMENT_ADDRESS=0x0000000000000000000000000000000000000000
X402_PRICE_USDC=0.01
X402_ENABLED=false
X402_NETWORK=eip155:137
X402_ASSET=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# Canopy Route Intelligence runtime.
CANOPY_RUNTIME_MODE=demo
CANOPY_CORRIDOR_BIGQUERY=false
CANOPY_CORRIDOR_CONFIG_URI=gs://your-bucket/canopy/corridors.v1.json
CANOPY_CORRIDOR_CONFIG_REFRESH_SECONDS=60
CANOPY_CONTEXT_GRAPH_ENABLED=true
CANOPY_CONTEXT_GRAPH_TIME_RANGES=1h
CANOPY_CONTEXT_GRAPH_MAX_BYTES_PER_QUERY=1000000000
CANOPY_CONTEXT_GRAPH_ETHEREUM_MODE=full
CANOPY_CONTEXT_GRAPH_POLYGON_MODE=transfer_only
CANOPY_ACTIVE_TOKENS=USDC,USDT,PYUSD

# Solana ingestion / Phase 16 BigQuery promotion.
SOLANA_RPC_PRIMARY_URL=https://your-solana-rpc.example/?api-key=replace-me
SOLANA_RPC_FALLBACK_URL=
SOLANA_WATCHED_ADDRESSES=replace-with-public-watched-address
SOLANA_TOKEN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOLANA_START_SIGNATURE=replace-with-finalized-start-signature
SOLANA_START_SLOT=
SOLANA_COMMITMENT=finalized
SOLANA_RPC_MAX_RPS=5
SOLANA_MAX_SIGNATURES_PER_RUN=50
SOLANA_MAX_TRANSACTIONS_PER_RUN=50
SOLANA_MAX_INNER_INSTRUCTIONS_PER_TX=64
SOLANA_RPC_TIMEOUT_SECONDS=10.0
SOLANA_CHECKPOINT_BACKEND=local_file
SOLANA_CHECKPOINT_PATH=data/solana_checkpoint.json
SOLANA_BQ_DATASET=solana_measured
SOLANA_BQ_TABLE=solana_transfers
SOLANA_CORRIDOR_INTELLIGENCE_PATH=data/solana_corridor_intelligence.json
ENV=development
